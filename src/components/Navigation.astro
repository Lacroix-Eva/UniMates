---
const menuItems = [
  {
    label: "Interactions",
    href: "/interactions/index.html",
    iconPath: "/icons/bulle.svg",
    iconClass: "scale-125",
    showBadge: true,
  },
  { label: "Stats", href: "/stats/index.html", iconPath: "/icons/stat.svg" },
  {
    label: "Ressources",
    href: "/ressource/index.html",
    iconPath: "/icons/Ressources.svg",
  },
  {
    label: "Profil",
    href: "/profile/index.html",
    iconPath: "/icons/profil.svg",
  },
];
---

<nav
  class="fixed bottom-0 left-0 right-0 z-50 pb-2
         bg-white border-t border-base-300
         shadow-md"
>
  <ul class="flex justify-around items-center py-3">
    {
      menuItems.map((item) => (
        <li>
          <a
            href={item.href}
            class="flex flex-col items-center gap-1
                 text-sm text-base-content relative"
          >
            <span class="relative inline-flex items-center justify-center w-6 h-6 leading-none">
              {item.iconPath ? (
                <img
                  src={item.iconPath}
                  alt={item.label}
                  class={`w-full h-full object-contain block ${item.iconClass || ""}`}
                />
              ) : (
                <span class="text-xl leading-none" aria-hidden="true" />
              )}
              {item.showBadge && (
                <span
                  id="notificationBadge"
                  class="absolute -top-1 -right-1 bg-error text-error-content text-xs font-bold rounded-full w-5 h-5 items-center justify-center"
                  style="display: none;"
                >
                  0
                </span>
              )}
            </span>
            <span>{item.label}</span>
          </a>
        </li>
      ))
    }
  </ul>
</nav>

<script type="module">
  import pb from "/pocketbase/pb.js";

  // Fonction pour calculer les messages non lus
  const calculateUnreadMessages = async () => {
    try {
      if (!pb.authStore.isValid) return;

      const userId = pb.authStore.model.id;

      // Récupérer toutes les conversations actives
      const conversations = await pb.collection("conversations").getFullList({
        filter: `(user1 = "${userId}" || user2 = "${userId}") && status = "active"`,
      });

      console.log(
        "🔍 Calcul des messages non lus pour",
        conversations.length,
        "conversations",
      );

      const unreadMessages = {};

      for (const conv of conversations) {
        const lastReadTime = localStorage.getItem(`lastRead_${conv.id}`);

        // Compter les messages non lus
        let unreadCount = 0;
        if (lastReadTime) {
          const unreadMsgs = await pb
            .collection("conversation_messages")
            .getList(1, 100, {
              filter: `conversation = "${conv.id}" && sender != "${userId}" && created > "${lastReadTime}"`,
            });
          unreadCount = unreadMsgs.totalItems;
        } else {
          // Si jamais ouvert, compter tous les messages de l'autre
          const unreadMsgs = await pb
            .collection("conversation_messages")
            .getList(1, 100, {
              filter: `conversation = "${conv.id}" && sender != "${userId}"`,
            });
          unreadCount = unreadMsgs.totalItems;
        }

        if (unreadCount > 0) {
          unreadMessages[conv.id] = unreadCount;
          console.log(
            `📬 Conversation ${conv.id}: ${unreadCount} messages non lus`,
          );
        }
      }

      console.log(
        "💾 [Navigation] Sauvegarde des messages non lus:",
        unreadMessages,
      );
      localStorage.setItem("unreadMessages", JSON.stringify(unreadMessages));
      updateNotificationBadge();
    } catch (err) {
      console.error(
        "❌ [Navigation] Erreur lors du calcul des messages non lus:",
        err,
      );
    }
  };

  // Fonction pour mettre à jour le badge de notifications
  const updateNotificationBadge = () => {
    const badge = document.getElementById("notificationBadge");
    if (!badge) return;

    const unreadMessages = JSON.parse(
      localStorage.getItem("unreadMessages") || "{}",
    );
    const totalUnread = Object.values(unreadMessages).reduce(
      (sum, count) => sum + count,
      0,
    );

    console.log("🔔 Mise à jour du badge:", {
      unreadMessages: JSON.stringify(unreadMessages),
      keys: Object.keys(unreadMessages),
      values: Object.values(unreadMessages),
      totalUnread,
    });

    if (totalUnread > 0) {
      badge.textContent = totalUnread > 99 ? "99+" : totalUnread;
      badge.style.display = "flex";
    } else {
      badge.style.display = "none";
    }
  };

  // Mettre à jour au chargement
  calculateUnreadMessages();

  // Écouter les changements dans localStorage
  window.addEventListener("storage", () => {
    console.log("📢 Événement storage détecté");
    updateNotificationBadge();
  });

  // Recalculer les messages non lus toutes les 10 secondes
  setInterval(calculateUnreadMessages, 10000);
</script>
