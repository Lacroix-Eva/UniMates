---
import LayoutProtege from "../../../layouts/LayoutProtege.astro";
---

<LayoutProtege
  nomPage="Enregistrer mon mood"
  titre_page="Comment te sens-tu ?"
  intro_page="Prends un moment pour toi"
>
  <div class="w-full max-w-sm mx-auto space-y-6">
    <form id="moodForm" class="space-y-6">
      <div
        class="bg-base-300 border-2 rounded-4xl shadow-md p-6 space-y-4 bg-gradient-custom"
      >
        <h3 class="text-center">Ton humeur du jour</h3>

        <div class="grid grid-cols-3 gap-3">
          <label class="cursor-pointer">
            <input
              type="radio"
              name="mood"
              value="excellent"
              class="sr-only peer"
              required
            />
            <div
              class="bg-base-100 border-2 border-base-content/20 rounded-3xl p-4 flex flex-col items-center gap-2 transition-all peer-checked:border-success peer-checked:bg-success/10 active:scale-95"
            >
              <span class="text-4xl">😊</span>
              <span class="text-xs font-semibold">Excellent</span>
            </div>
          </label>

          <label class="cursor-pointer">
            <input
              type="radio"
              name="mood"
              value="bien"
              class="sr-only peer"
              required
            />
            <div
              class="bg-base-100 border-2 border-base-content/20 rounded-3xl p-4 flex flex-col items-center gap-2 transition-all peer-checked:border-primary peer-checked:bg-primary/10 active:scale-95"
            >
              <span class="text-4xl">🙂</span>
              <span class="text-xs font-semibold">Bien</span>
            </div>
          </label>

          <label class="cursor-pointer">
            <input
              type="radio"
              name="mood"
              value="neutre"
              class="sr-only peer"
              required
            />
            <div
              class="bg-base-100 border-2 border-base-content/20 rounded-3xl p-4 flex flex-col items-center gap-2 transition-all peer-checked:border-warning peer-checked:bg-warning/10 active:scale-95"
            >
              <span class="text-4xl">😐</span>
              <span class="text-xs font-semibold">Neutre</span>
            </div>
          </label>

          <label class="cursor-pointer">
            <input
              type="radio"
              name="mood"
              value="moyen"
              class="sr-only peer"
              required
            />
            <div
              class="bg-base-100 border-2 border-base-content/20 rounded-3xl p-4 flex flex-col items-center gap-2 transition-all peer-checked:border-accent peer-checked:bg-accent/10 active:scale-95"
            >
              <span class="text-4xl">😕</span>
              <span class="text-xs font-semibold">Moyen</span>
            </div>
          </label>

          <label class="cursor-pointer">
            <input
              type="radio"
              name="mood"
              value="difficile"
              class="sr-only peer"
              required
            />
            <div
              class="bg-base-100 border-2 border-base-content/20 rounded-3xl p-4 flex flex-col items-center gap-2 transition-all peer-checked:border-error peer-checked:bg-error/10 active:scale-95"
            >
              <span class="text-4xl">😢</span>
              <span class="text-xs font-semibold">Difficile</span>
            </div>
          </label>
        </div>
      </div>

      <div
        class="bg-gradient-custom border-2 rounded-4xl shadow-md p-6 space-y-4"
      >
        <div class="space-y-2">
          <h3 class="text-center">Précise ton état (optionnel)</h3>
          <p class="text-center opacity-75">
            Choisis le(s) mot(s) qui ressemble(nt) le plus a ton ressenti du
            moment.
          </p>
        </div>

        <input type="hidden" id="moodDetailInput" name="moodDetail" value="" />

        <div class="flex flex-wrap gap-3 justify-center">
          <button
            type="button"
            class="mood-detail-chip inline-flex items-center justify-center px-4 py-2 rounded-full border-2 border-base-content/20 bg-base-100 text-sm font-medium transition-all duration-200 active:scale-95"
            data-value="Motivé"
            aria-pressed="false">Motivé</button
          >
          <button
            type="button"
            class="mood-detail-chip inline-flex items-center justify-center px-4 py-2 rounded-full border-2 border-base-content/20 bg-base-100 text-sm font-medium transition-all duration-200 active:scale-95"
            data-value="Satisfait"
            aria-pressed="false">Satisfait</button
          >
          <button
            type="button"
            class="mood-detail-chip inline-flex items-center justify-center px-4 py-2 rounded-full border-2 border-base-content/20 bg-base-100 text-sm font-medium transition-all duration-200 active:scale-95"
            data-value="Inspiré"
            aria-pressed="false">Inspiré</button
          >
          <button
            type="button"
            class="mood-detail-chip inline-flex items-center justify-center px-4 py-2 rounded-full border-2 border-base-content/20 bg-base-100 text-sm font-medium transition-all duration-200 active:scale-95"
            data-value="Joyeux"
            aria-pressed="false">Joyeux</button
          >
          <button
            type="button"
            class="mood-detail-chip inline-flex items-center justify-center px-4 py-2 rounded-full border-2 border-base-content/20 bg-base-100 text-sm font-medium transition-all duration-200 active:scale-95"
            data-value="Fatigué"
            aria-pressed="false">Fatigué</button
          >
          <button
            type="button"
            class="mood-detail-chip inline-flex items-center justify-center px-4 py-2 rounded-full border-2 border-base-content/20 bg-base-100 text-sm font-medium transition-all duration-200 active:scale-95"
            data-value="Apaisé"
            aria-pressed="false">Apaisé</button
          >
          <button
            type="button"
            class="mood-detail-chip inline-flex items-center justify-center px-4 py-2 rounded-full border-2 border-base-content/20 bg-base-100 text-sm font-medium transition-all duration-200 active:scale-95"
            data-value="Stressé"
            aria-pressed="false">Stressé</button
          >
          <button
            type="button"
            class="mood-detail-chip inline-flex items-center justify-center px-4 py-2 rounded-full border-2 border-base-content/20 bg-base-100 text-sm font-medium transition-all duration-200 active:scale-95"
            data-value="Reconnaissant"
            aria-pressed="false">Reconnaissant</button
          >
          <button
            type="button"
            class="mood-detail-chip inline-flex items-center justify-center px-4 py-2 rounded-full border-2 border-base-content/20 bg-base-100 text-sm font-medium transition-all duration-200 active:scale-95"
            data-value="Curieux"
            aria-pressed="false">Curieux</button
          >
          <button
            type="button"
            class="mood-detail-chip inline-flex items-center justify-center px-4 py-2 rounded-full border-2 border-base-content/20 bg-base-100 text-sm font-medium transition-all duration-200 active:scale-95"
            data-value="Confiant"
            aria-pressed="false">Confiant</button
          >
          <button
            type="button"
            class="mood-detail-chip inline-flex items-center justify-center px-4 py-2 rounded-full border-2 border-base-content/20 bg-base-100 text-sm font-medium transition-all duration-200 active:scale-95"
            data-value="Fier"
            aria-pressed="false">Fier</button
          >
          <button
            type="button"
            class="mood-detail-chip inline-flex items-center justify-center px-4 py-2 rounded-full border-2 border-base-content/20 bg-base-100 text-sm font-medium transition-all duration-200 active:scale-95"
            data-value="Calme"
            aria-pressed="false">Calme</button
          >
          <button
            type="button"
            class="mood-detail-chip inline-flex items-center justify-center px-4 py-2 rounded-full border-2 border-base-content/20 bg-base-100 text-sm font-medium transition-all duration-200 active:scale-95"
            data-value="Soulagé"
            aria-pressed="false">Soulagé</button
          >
          <button
            type="button"
            class="mood-detail-chip inline-flex items-center justify-center px-4 py-2 rounded-full border-2 border-base-content/20 bg-base-100 text-sm font-medium transition-all duration-200 active:scale-95"
            data-value="Debordé"
            aria-pressed="false">Debordé</button
          >
          <button
            type="button"
            class="mood-detail-chip inline-flex items-center justify-center px-4 py-2 rounded-full border-2 border-base-content/20 bg-base-100 text-sm font-medium transition-all duration-200 active:scale-95"
            data-value="Perdu"
            aria-pressed="false">Perdu</button
          >
          <button
            type="button"
            class="mood-detail-chip inline-flex items-center justify-center px-4 py-2 rounded-full border-2 border-base-content/20 bg-base-100 text-sm font-medium transition-all duration-200 active:scale-95"
            data-value="Frusté"
            aria-pressed="false">Frustré</button
          >
          <button
            type="button"
            class="mood-detail-chip inline-flex items-center justify-center px-4 py-2 rounded-full border-2 border-base-content/20 bg-base-100 text-sm font-medium transition-all duration-200 active:scale-95"
            data-value="Anxieux"
            aria-pressed="false">Anxieux</button
          >
          <button
            type="button"
            class="mood-detail-chip inline-flex items-center justify-center px-4 py-2 rounded-full border-2 border-base-content/20 bg-base-100 text-sm font-medium transition-all duration-200 active:scale-95"
            data-value="Solitaire"
            aria-pressed="false">Solitaire</button
          >
        </div>
      </div>

      <!-- Note optionnelle -->
      <div
        class="bg-gradient-custom border-2 rounded-4xl shadow-md p-6 space-y-3"
      >
        <label
          for="note"
          class="font-balsamiq-sans font-extrabold leading-[160%] text-lg text-center block"
        >
          Ajoute une note (optionnel)
        </label>
        <textarea
          id="note"
          name="note"
          rows="3"
          placeholder="Qu'est-ce qui t'a marqué aujourd'hui ?"
          class="w-full bg-base-100 border-2 rounded-3xl shadow-sm px-4 py-3 text-base-content placeholder:text-base-content/60 resize-none"
        ></textarea>
      </div>

      <div
        class="bg-success/10 border-2 border-success/30 rounded-4xl shadow-md p-6 space-y-2"
      >
        <h3 class="text-center">Félicitations !</h3>
        <p class="text-center">
          Super ! Prendre note de ton humeur t'aide a mieux te comprendre et a
          reperer ce qui te fait du bien.
        </p>
      </div>

      <!-- Message d'erreur/succès -->
      <p id="message" class="text-center text-sm font-semibold"></p>

      <!-- Boutons -->
      <div class="space-y-3">
        <button
          type="submit"
          id="submitButton"
          class="flex w-fit items-center justify-center text-base-content font-balsamiq-sans font-bold text-lg py-3 px-10 border-2 rounded-4xl shadow-md transition-all duration-300 ease-in-out transform bg-base-300 active:bg-info cursor-pointer disabled:opacity-50 disabled:cursor-not-allowed mx-auto"
        >
          Enregistrer
        </button>

        <a
          href="/accueil/index.html"
          class="inline-flex items-center justify-center text-base-content font-balsamiq-sans text-base py-2 px-8 w-full transition-all opacity-70 hover:opacity-100"
        >
          Retour
        </a>
      </div>
    </form>
  </div>
</LayoutProtege>

<script type="module" is:inline>
  import pb from "/pocketbase/pb.js";

  // Rediriger si pas connecté
  if (!pb.authStore.isValid) {
    window.location.href = "/connexion/index.html";
  }

  const form = document.getElementById("moodForm");
  const message = document.getElementById("message");
  const submitButton = document.getElementById("submitButton");
  const moodDetailInput = document.getElementById("moodDetailInput");
  const moodDetailChips = document.querySelectorAll(".mood-detail-chip");
  let selectedMoodDetails = [];

  const getTodayRangeIso = () => {
    const now = new Date();
    const start = new Date(
      now.getFullYear(),
      now.getMonth(),
      now.getDate(),
      0,
      0,
      0,
      0,
    );
    const end = new Date(
      now.getFullYear(),
      now.getMonth(),
      now.getDate(),
      23,
      59,
      59,
      999,
    );

    return {
      startIso: start.toISOString(),
      endIso: end.toISOString(),
    };
  };

  const fetchTodayMoods = async (userId) => {
    const { startIso, endIso } = getTodayRangeIso();
    return pb.collection("moods").getFullList({
      filter: `user = "${userId}" && created >= "${startIso}" && created <= "${endIso}"`,
      sort: "-created",
    });
  };

  const loadTodayMood = async () => {
    if (!pb.authStore.isValid || !pb.authStore.model) {
      return null;
    }

    try {
      const userId = pb.authStore.model.id;
      const moods = await fetchTodayMoods(userId);
      const todayMood = moods[0] || null;
      if (!todayMood) {
        submitButton.textContent = "Enregistrer";
        return null;
      }

      const moodRadio = form.querySelector(
        `input[name="mood"][value="${todayMood.mood}"]`,
      );
      if (moodRadio) {
        moodRadio.checked = true;
      }

      const noteField = form.querySelector("#note");
      if (noteField) {
        noteField.value = (todayMood.note || "").toString();
      }

      const details = (todayMood.mood_details || "")
        .toString()
        .split(",")
        .map((item) => item.trim())
        .filter(Boolean);

      selectedMoodDetails = details;
      syncMoodDetailChips();

      submitButton.textContent = "Mettre a jour";
      message.textContent =
        "Tu as deja un mood aujourd'hui. Tu peux le modifier.";
      message.className = "text-center text-sm font-semibold text-info";

      return todayMood;
    } catch (err) {
      console.error("Erreur lors du chargement du mood du jour:", err);
      return null;
    }
  };

  const syncMoodDetailChips = () => {
    moodDetailInput.value = selectedMoodDetails.join(", ");

    moodDetailChips.forEach((chip) => {
      const isSelected = selectedMoodDetails.includes(chip.dataset.value);
      chip.setAttribute("aria-pressed", isSelected ? "true" : "false");
      chip.classList.toggle("border-primary", isSelected);
      chip.classList.toggle("bg-primary", isSelected);
      chip.classList.toggle("text-primary-content", isSelected);
      chip.classList.toggle("shadow-md", isSelected);
      chip.classList.toggle("scale-105", isSelected);
      chip.classList.toggle("-translate-y-0.5", isSelected);
    });
  };

  moodDetailChips.forEach((chip) => {
    chip.addEventListener("click", () => {
      const value = chip.dataset.value;

      if (selectedMoodDetails.includes(value)) {
        selectedMoodDetails = selectedMoodDetails.filter(
          (item) => item !== value,
        );
      } else {
        selectedMoodDetails = [...selectedMoodDetails, value];
      }

      syncMoodDetailChips();
    });
  });

  syncMoodDetailChips();

  let cachedTodayMood = null;
  submitButton.disabled = true;
  loadTodayMood().then((todayMood) => {
    cachedTodayMood = todayMood;
    submitButton.disabled = false;
  });

  form.addEventListener("submit", async (e) => {
    e.preventDefault();

    const formData = new FormData(form);
    const mood = formData.get("mood");
    const moodDetail = (formData.get("moodDetail") || "").toString().trim();
    const note = formData.get("note");
    const noteText = (note || "").toString().trim();

    if (!mood) {
      message.textContent = "Merci de sélectionner ton humeur";
      message.className = "text-center text-sm font-semibold text-error";
      return;
    }

    submitButton.disabled = true;
    message.textContent = "Enregistrement...";
    message.className = "text-center text-sm font-semibold text-info";

    try {
      const userId = pb.authStore.model.id;
      const payload = {
        user: userId,
        mood: mood,
        note: noteText,
        mood_details: moodDetail,
      };

      // Always re-check today mood server-side right before saving to avoid race conditions.
      const todayMoods = await fetchTodayMoods(userId);
      cachedTodayMood = todayMoods[0] || null;

      let savedMood = null;
      let isUpdate = false;

      if (cachedTodayMood?.id) {
        isUpdate = true;
        savedMood = await pb
          .collection("moods")
          .update(cachedTodayMood.id, payload);
      } else {
        savedMood = await pb.collection("moods").create(payload);
      }

      const persistedMoodDetails = (savedMood.mood_details || "")
        .toString()
        .trim();

      if (moodDetail && !persistedMoodDetails) {
        const fallbackNote = noteText
          ? `${noteText}\n\nEtat precise: ${moodDetail}`
          : `Etat precise: ${moodDetail}`;

        savedMood = await pb.collection("moods").update(savedMood.id, {
          note: fallbackNote,
        });

        message.textContent = isUpdate
          ? "Mood mis a jour, mais la precision n'est pas supportee sur cette instance PocketBase (ajoutee dans la note)."
          : "Mood enregistre, mais la precision n'est pas supportee sur cette instance PocketBase (ajoutee dans la note).";
        message.className = "text-center text-sm font-semibold text-warning";

        setTimeout(() => {
          window.location.href = "/accueil/index.html";
        }, 2200);
        return;
      }

      cachedTodayMood = savedMood;

      message.textContent = isUpdate
        ? "✨ Mood mis a jour avec succes !"
        : "✨ Mood enregistre avec succes !";
      message.className = "text-center text-sm font-semibold text-success";

      // Rediriger vers l'accueil après 1.5s
      setTimeout(() => {
        window.location.href = "/accueil/index.html";
      }, 1500);
    } catch (err) {
      console.error("Erreur lors de l'enregistrement:", err);
      message.textContent =
        "Une erreur est survenue. Réessaie dans un instant.";
      message.className = "text-center text-sm font-semibold text-error";
      submitButton.disabled = false;
    }
  });
</script>
