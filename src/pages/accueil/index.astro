---
import LayoutProtege from "../../layouts/LayoutProtege.astro";
---

<LayoutProtege
  nomPage="Accueil"
  titre_page="Bonjour ... !"
  intro_page="(date_du_jour)"
>
  <div class="w-full max-w-sm mx-auto space-y-6">
    <div>
      <a
        href="/mood/enregistrer/index.html"
        class="bg-gradient-custom block bg-base-300 border-2 rounded-4xl shadow-md p-6 transition-all duration-300 ease-in-out transform active:bg-info cursor-pointer"
      >
        <div class="flex items-center justify-between gap-4">
          <div class="flex-1">
            <h2 id="moodCardTitle" class="text-left mb-1">
              Comment te sens-tu ?
            </h2>
            <p id="moodCardSubtitle" class="text-sm text-left opacity-80">
              Enregistre ton mood du jour
            </p>
          </div>
          <div class="text-4xl">→</div>
        </div>
      </a>
    </div>

    <!-- Card Interactions -->
    <a
      href="/interactions/index.html"
      class="bg-gradient-custom block bg-base-300 border-2 rounded-4xl shadow-md p-6 transition-all duration-300 ease-in-out transform active:bg-info cursor-pointer"
    >
      <div class="flex items-center justify-between gap-4">
        <div class="flex-1">
          <h2 class="text-left mb-1">Interactions</h2>
          <p id="interactionsCardSubtitle" class="text-sm text-left opacity-80">
            Connecte-toi avec d'autres
          </p>
          <p
            id="interactionsCardStatus"
            class="text-xs text-left mt-1 opacity-70"
          >
            Statut: Actif
          </p>
        </div>
        <div class="text-4xl">→</div>
      </div>
    </a>

    <!-- Card Familier -->
    <div
      class="bg-gradient-custom border-2 rounded-4xl shadow-md p-6 space-y-5"
    >
      <!-- En-tête avec familier -->
      <div
        class="flex items-center gap-4 pb-4 border-b-2 border-base-content/10"
      >
        <img
          id="cardFamilierImage"
          src="/familiers/plume.png"
          alt="Ton familier"
          class="w-16 h-16 object-contain"
        />
        <div class="flex-1">
          <p class="font-balsamiq-sans font-bold text-left">
            <span id="cardFamilierName">Plume</span>
          </p>
          <p class="text-left opacity-80">En croissance</p>
        </div>
      </div>

      <!-- Section progression -->
      <div class="space-y-3">
        <div class="flex justify-between items-baseline">
          <h3 class="text-left">Progression</h3>
          <p class="text-sm">
            <span id="moodCount" class="font-bold text-accent">0</span>
            <span class="opacity-70">/10 moods</span>
          </p>
        </div>

        <progress
          id="moodProgress"
          class="progress progress-accent w-full h-3"
          value="0"
          max="10"></progress>

        <p id="progressStatus" class="text-sm text-center opacity-80 py-2">
          Chaque mood aide <span id="familierNameInStatus" class="font-semibold"
            >Plume</span
          > à grandir !
        </p>
      </div>
    </div>

    <!-- Card Parler avec le familier -->
    <a
      href="/familier/parler/index.html"
      class="bg-gradient-custom block bg-base-300 border-2 rounded-4xl shadow-md p-6 transition-all duration-300 ease-in-out transform active:bg-info cursor-pointer"
    >
      <div class="flex items-center justify-between gap-4">
        <div class="flex-1">
          <h2 class="text-left mb-1">Besoin de parler ?</h2>
          <p class="text-sm text-left opacity-80">Discute avec ton familier</p>
        </div>
        <div class="text-4xl">→</div>
      </div>
    </a>

    <!-- Card Ressource d'accompagnement -->
    <a
      href="/ressource/index.html"
      class="bg-gradient-custom block bg-base-300 border-2 rounded-4xl shadow-md p-6 transition-all duration-300 ease-in-out transform active:bg-info cursor-pointer"
    >
      <div class="flex items-center justify-between gap-4">
        <div class="flex-1">
          <h2 class="text-left mb-1">Ressource d'accompagnement</h2>
          <p class="text-sm text-left opacity-80">
            Outils et conseils bien-etre
          </p>
        </div>
        <div class="text-4xl">→</div>
      </div>
    </a>
  </div>
</LayoutProtege>

<script type="module" is:inline>
  import pb from "/pocketbase/pb.js";

  const headerFamilierImage = document.getElementById("familierImage");
  const cardFamilierImage = document.getElementById("cardFamilierImage");
  const cardFamilierName = document.getElementById("cardFamilierName");
  const familierNameInStatus = document.getElementById("familierNameInStatus");
  const progressStatus = document.getElementById("progressStatus");
  const moodCount = document.getElementById("moodCount");
  const moodProgress = document.getElementById("moodProgress");
  const moodCardTitle = document.getElementById("moodCardTitle");
  const moodCardSubtitle = document.getElementById("moodCardSubtitle");
  const interactionsCardSubtitle = document.getElementById(
    "interactionsCardSubtitle",
  );
  const interactionsCardStatus = document.getElementById(
    "interactionsCardStatus",
  );

  const updateMoodCardTexts = (hasMoodToday) => {
    if (moodCardTitle) {
      moodCardTitle.textContent = hasMoodToday
        ? "Tu veux changer ton mood du jour ?"
        : "Comment te sens-tu ?";
    }

    if (moodCardSubtitle) {
      moodCardSubtitle.textContent = hasMoodToday
        ? "Tu peux le mettre a jour si besoin"
        : "Enregistre ton mood du jour";
    }
  };

  const getTodayRangeIso = () => {
    const now = new Date();
    const start = new Date(
      now.getFullYear(),
      now.getMonth(),
      now.getDate(),
      0,
      0,
      0,
      0,
    );
    const end = new Date(
      now.getFullYear(),
      now.getMonth(),
      now.getDate(),
      23,
      59,
      59,
      999,
    );

    return {
      startIso: start.toISOString(),
      endIso: end.toISOString(),
    };
  };

  let currentUser = null;

  const baseImages = {
    plume: "/familiers/plume.png",
    sunny: "/familiers/sunny.png",
    buzzy: "/familiers/buzzy.png",
  };

  const familierNames = {
    plume: "Plume",
    sunny: "Sunny",
    buzzy: "Buzzy",
  };

  const getCurrentUser = async () => {
    if (!pb.authStore.isValid || !pb.authStore.model) {
      return null;
    }

    if (currentUser) {
      return currentUser;
    }

    currentUser = pb.authStore.model;
    try {
      const userId = pb.authStore.model.id;
      currentUser = await pb.collection("users").getOne(userId);
    } catch (err) {
      console.error("Erreur lors du chargement du profil:", err);
    }

    return currentUser;
  };

  const loadFamilier = async () => {
    const user = await getCurrentUser();
    if (!user) {
      return;
    }

    const rawFamilier = (user.familier || "Plume").toString().toLowerCase();
    const familierKey = baseImages[rawFamilier] ? rawFamilier : "plume";

    // Charger l'image personnalisée si disponible
    let imagePath = baseImages[familierKey];

    // Parser customisation si c'est une string JSON
    let customisation = user.customisation || {};
    if (typeof customisation === "string") {
      try {
        customisation = JSON.parse(customisation);
      } catch {
        customisation = {};
      }
    }

    if (customisation && customisation.variantId) {
      const variantId = customisation.variantId;
      const variantIndex = parseInt(variantId.split("_")[1]) - 1;
      const variants = {
        plume: [
          "/familiers/plume.png",
          "/familiers/plume2.png",
          "/familiers/plume3.png",
          "/familiers/plume4.png",
          "/familiers/plume5.png",
          "/familiers/plume6.png",
          "/familiers/plume7.png",
        ],
        sunny: [
          "/familiers/sunny.png",
          "/familiers/sunny2.png",
          "/familiers/sunny3.png",
          "/familiers/sunny4.png",
          "/familiers/sunny5.png",
          "/familiers/sunny6.png",
          "/familiers/sunny7.png",
        ],
        buzzy: [
          "/familiers/buzzy.png",
          "/familiers/buzzy2.png",
          "/familiers/buzzy3.png",
          "/familiers/buzzy4.png",
          "/familiers/buzzy5.png",
          "/familiers/buzzy6.png",
          "/familiers/buzzy7.png",
        ],
      };

      const list = variants[familierKey] || variants.plume;
      imagePath = list[variantIndex] || list[0];
    }

    const displayName = familierNames[familierKey] || "Ton familier";

    if (headerFamilierImage) {
      headerFamilierImage.src = imagePath;
    }

    if (cardFamilierImage) {
      cardFamilierImage.src = imagePath;
      cardFamilierImage.alt = displayName;
    }

    if (cardFamilierName) {
      cardFamilierName.textContent = displayName;
    }

    if (familierNameInStatus) {
      familierNameInStatus.textContent = displayName;
    }
  };

  const loadInteractionsStatus = async () => {
    const user = await getCurrentUser();
    if (!user) {
      return;
    }

    const interactionsActive = user.interactionsActive !== false;

    if (interactionsCardSubtitle) {
      interactionsCardSubtitle.textContent = interactionsActive
        ? "Connecte-toi avec d'autres"
        : "Tes interactions sont en pause";
    }

    if (interactionsCardStatus) {
      interactionsCardStatus.textContent = interactionsActive
        ? "Statut: Actif"
        : "Statut: En pause";
    }
  };

  const loadMoodProgress = async () => {
    const user = await getCurrentUser();
    if (!user) {
      return;
    }

    try {
      const userId = user.id;
      const moods = await pb.collection("moods").getFullList({
        filter: `user = "${userId}"`,
      });

      const count = moods.length;
      const maxMoods = 10;
      const progressValue = Math.min(count, maxMoods);
      const remaining = Math.max(0, maxMoods - count);

      const { startIso, endIso } = getTodayRangeIso();
      const moodsToday = await pb.collection("moods").getList(1, 1, {
        filter: `user = "${userId}" && created >= "${startIso}" && created <= "${endIso}"`,
      });
      const hasMoodToday = moodsToday.totalItems > 0;

      if (moodCount) moodCount.textContent = count;
      if (moodProgress) {
        moodProgress.value = progressValue;
        moodProgress.max = maxMoods;
      }

      updateMoodCardTexts(hasMoodToday);

      if (progressStatus) {
        const familierName = cardFamilierName?.textContent || "ton familier";
        if (remaining === 0) {
          progressStatus.innerHTML = `🎉 Bravo ! <span class="font-semibold">${familierName}</span> a atteint son objectif !`;
        } else if (count === 0) {
          progressStatus.innerHTML = `Commence à enregistrer tes moods pour aider <span class="font-semibold">${familierName}</span> à grandir !`;
        } else {
          progressStatus.innerHTML = `Continue ! Encore ${remaining} mood${remaining > 1 ? "s" : ""} pour aider <span class="font-semibold">${familierName}</span> ✨`;
        }
      }

      console.log("Moods loaded:", count);
    } catch (err) {
      console.error("Erreur lors du chargement des moods:", err);
      // Si la collection n'existe pas encore, on initialise avec 0
      if (moodCount) moodCount.textContent = "0";
      if (moodProgress) {
        moodProgress.value = 0;
        moodProgress.max = 10;
      }
      if (moodCardTitle) moodCardTitle.textContent = "Comment te sens-tu ?";
      if (moodCardSubtitle)
        moodCardSubtitle.textContent = "Enregistre ton mood du jour";
    }
  };

  loadFamilier();
  loadInteractionsStatus();
  loadMoodProgress();
</script>
