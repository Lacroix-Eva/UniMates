---
import LayoutProtege from "../../layouts/LayoutProtege.astro";
---

<LayoutProtege
  nomPage="Profil"
  titre_page="Ton profil"
  intro_page="Retrouve tes infos et tes reglages"
>
  <div class="w-full max-w-sm mx-auto space-y-6">
    <div
      class="bg-gradient-custom border-2 rounded-4xl shadow-md p-6 space-y-4"
    >
      <h2 class="text-left">Mes infos</h2>

      <div class="space-y-2 text-sm">
        <p class="text-left">
          <span class="font-bold">Pseudo:</span>
          <span id="profilePseudo">Chargement...</span>
        </p>
        <p class="text-left">
          <span class="font-bold">Email:</span>
          <span id="profileEmail">Chargement...</span>
        </p>
        <p class="text-left">
          <span class="font-bold">Familier:</span>
          <span id="profileFamilier">Chargement...</span>
        </p>
        <p class="text-left">
          <span class="font-bold">Points:</span>
          <span id="profilePoints">0</span>
        </p>
        <p class="text-left">
          <span class="font-bold">Compte créé le:</span>
          <span id="profileCreatedAt">-</span>
        </p>
      </div>
    </div>

    <a
      href="/profil/personnalisation/index.html"
      class="bg-gradient-custom block border-2 rounded-4xl shadow-md p-6 transition-all duration-300 ease-in-out transform active:bg-info cursor-pointer"
    >
      <div class="flex items-center justify-between gap-4">
        <div class="flex-1">
          <h2 class="text-left mb-1">Personnalisation</h2>
          <p class="text-sm text-left opacity-80">
            Modifie ton profil et ton familier.
          </p>
        </div>
        <div class="text-4xl">→</div>
      </div>
    </a>

    <a
      href="/profil/autorisation/index.html"
      class="bg-gradient-custom block border-2 rounded-4xl shadow-md p-6 transition-all duration-300 ease-in-out transform active:bg-info cursor-pointer"
    >
      <div class="flex items-center justify-between gap-4">
        <div class="flex-1">
          <h2 class="text-left mb-1">Autorisations</h2>
          <p class="text-sm text-left opacity-80">
            Gere tes preferences, notifications et confidentialite.
          </p>
        </div>
        <div class="text-4xl">→</div>
      </div>
    </a>

    <!-- Bouton déconnexion -->
    <div class="flex justify-center">
      <button
        id="logoutButton"
        class="inline-flex items-center justify-center text-base-content font-balsamiq-sans font-bold text-lg py-3 px-10 border-2 rounded-4xl shadow-md transition-all duration-300 ease-in-out transform bg-base-300 active:bg-info cursor-pointer"
      >
        Se déconnecter
      </button>
    </div>
  </div>
</LayoutProtege>

<script type="module" is:inline>
  import pb from "/pocketbase/pb.js";

  const pseudoEl = document.getElementById("profilePseudo");
  const emailEl = document.getElementById("profileEmail");
  const familierEl = document.getElementById("profileFamilier");
  const pointsEl = document.getElementById("profilePoints");
  const createdAtEl = document.getElementById("profileCreatedAt");

  const formatDateFr = (value) => {
    if (!value) return "-";
    const date = new Date(value);
    if (Number.isNaN(date.getTime())) return "-";
    return date.toLocaleDateString("fr-FR", {
      day: "2-digit",
      month: "2-digit",
      year: "numeric",
    });
  };

  const loadProfile = async () => {
    if (!pb.authStore.isValid || !pb.authStore.model) {
      window.location.href = "/connexion/index.html";
      return;
    }

    try {
      const userId = pb.authStore.model.id;
      const user = await pb.collection("users").getOne(userId);

      if (pseudoEl) {
        pseudoEl.textContent = user.pseudo || user.username || "-";
      }
      if (emailEl) {
        emailEl.textContent = user.email || "-";
      }
      if (familierEl) {
        familierEl.textContent = user.familier || "-";
      }
      if (pointsEl) {
        pointsEl.textContent = String(user.points ?? 0);
      }
      if (createdAtEl) {
        createdAtEl.textContent = formatDateFr(user.created);
      }
    } catch (error) {
      console.error("Erreur lors du chargement du profil:", error);
      if (pseudoEl) pseudoEl.textContent = "Erreur";
      if (emailEl) emailEl.textContent = "Erreur";
      if (familierEl) familierEl.textContent = "Erreur";
      if (pointsEl) pointsEl.textContent = "-";
      if (createdAtEl) createdAtEl.textContent = "-";
    }
  };

  loadProfile();

  const logoutButton = document.getElementById("logoutButton");
  logoutButton.addEventListener("click", () => {
    pb.authStore.clear();
    window.location.href = "/";
  });
</script>
