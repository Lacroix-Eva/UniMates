    if (strategy === "validate_and_clarify") {
      return sentenceCase(
        joinParts(
          transition,
          validation,
          generic,
          clarifyFallbacks[emotion] || clarifyFallbacks.neutre
        )
      );
    }

    if (strategy === "clarify") {
      return sentenceCase(
        joinParts(
          validation,
          "J'aimerais bien comprendre un peu mieux ce que tu traverses.",
          clarifyFallbacks[emotion] || clarifyFallbacks.neutre
