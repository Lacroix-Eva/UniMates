    const branch = CONTEXTUAL_CELEBRATIONS[eventType];
    if (!branch) return "";
    const pool = branch[topic] || branch.general || [];
    return uniquePick(pool, `celebrate_${eventType}_${topic}`);
  };

  const getDeepenLine = (emotion, topic) => {
    const branch = CONTEXTUAL_DEEPEN[emotion];
    if (!branch) return "";
    const pool = branch[topic] || branch.general || [];
    return uniquePick(pool, `deepen_${emotion}_${topic}`);
  };

