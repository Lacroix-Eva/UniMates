const detectCrisis = (text) => {
  const lower = text.toLowerCase();
  for (const w of CRISIS_KEYWORDS) {
    if (lower.includes(w)) return "crise";
  }
  for (const w of SELFHARM_KEYWORDS) {
    if (lower.includes(w)) return "automutilation";
  }
  return null;
};

