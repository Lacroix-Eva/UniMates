    "Est-ce qu'il y a quelqu'un à qui tu pourrais parler de tout ça ?",
  ],
  energique: [
    "Hey, c'est quoi la prochaine étape pour toi ?",
    "T'as quelqu'un sur qui tu peux compter autour de toi ?",
    "C'est quoi une petite chose que tu pourrais faire aujourd'hui pour aller mieux ?",
    "Comment tu te sens là, maintenant ?",
    "T'as déjà vécu quelque chose de similaire et tu t'en es sorti·e ?",
    "Qu'est-ce qui t'aiderait là, maintenant ?",
  ],
};

const shouldAskFollowUp = () => {
  return conversationContext.messageCount > 0 &&
    conversationContext.messageCount % 3 === 0 &&
    !conversationContext.askedQuestion;
};

const getFollowUp = (style) => {
  const pool = FOLLOW_UPS[style] || FOLLOW_UPS.doux;
  return pool[Math.floor(Math.random() * pool.length)];
};

// ============================================================
// ÉTAT DE L'APP
// ============================================================
let familierKey = "plume";
let familierImagePath = "/familiers/plume.png";
let familierName = "Plume";
let familierStyle = "doux";

const familierAvatarMsg = document.getElementById("familierAvatarMsg");
const welcomeText = document.getElementById("welcomeText");
const messagesContainer = document.getElementById("messagesContainer");
const messageInput = document.getElementById("messageInput");
const sendButton = document.getElementById("sendButton");
const typingIndicator = document.getElementById("typingIndicator");

// ============================================================
// CHARGEMENT DU FAMILIER
// ============================================================
const loadFamilier = async () => {
  if (!pb.authStore.isValid || !pb.authStore.model) return;
  try {
    const user = await pb.collection("users").getOne(pb.authStore.model.id);
    const raw = (user.familier || "plume").toString().toLowerCase();
    familierKey = FAMILIERS_CONFIG[raw] ? raw : "plume";
    const config = FAMILIERS_CONFIG[familierKey];
    familierStyle = config.style;

    let customisation = user.customisation || {};
    if (typeof customisation === "string") {
      try { customisation = JSON.parse(customisation); } catch { customisation = {}; }
    }

    familierImagePath = config.images[0];
    if (customisation?.variantId) {
      const idx = parseInt(customisation.variantId.split("_")[1], 10) - 1;
      familierImagePath = config.images[idx] || config.images[0];
    }

    familierName = config.name;

    if (familierAvatarMsg) {
      familierAvatarMsg.src = familierImagePath;
      familierAvatarMsg.alt = familierName;
    }
    if (welcomeText) {
      const welcomes = {
        doux: `Coucou ! Je suis ${familierName} et je suis là pour toi. 🌟 Comment tu vas aujourd'hui ?`,
        sage: `Bonjour ! Je suis ${familierName}. Je suis là pour t'écouter. Comment tu vas ?`,
        energique: `HEYYY ! Je suis ${familierName} et je suis trop content·e que tu sois là !! Comment tu vas ?!`,
      };
      welcomeText.textContent = welcomes[familierStyle] || welcomes.doux;
    }
  } catch (err) {
    console.error("Erreur chargement familier:", err);
  }
};

// ============================================================
// UI
// ============================================================
const appendMessage = (text, isUser, isCrisis = false) => {
  const emptyState = messagesContainer.querySelector(".text-center");
  if (emptyState) emptyState.remove();

  const div = document.createElement("div");
  div.className = `chat ${isUser ? "chat-end" : "chat-start"}`;

  if (!isUser) {
    const imageDiv = document.createElement("div");
    imageDiv.className = "chat-image";
    const avatar = document.createElement("img");
    avatar.src = familierImagePath;
    avatar.alt = familierName;
    avatar.className = "w-10 h-10 object-contain";
    imageDiv.appendChild(avatar);
    div.appendChild(imageDiv);
  }

  const bubble = document.createElement("div");
  bubble.className = `chat-bubble ${isUser ? "chat-bubble-accent" : isCrisis ? "chat-bubble-warning" : "chat-bubble-secondary"}`;
  bubble.textContent = text;
  div.appendChild(bubble);

  // Lien cliquable vers le 3114 si crise
  if (isCrisis) {
    const link = document.createElement("a");
    link.href = "tel:3114";
    link.className = "btn btn-warning btn-sm mt-2 w-full";
    link.textContent = "📞 Appeler le 3114 maintenant";
    div.appendChild(link);
  }

  messagesContainer.appendChild(div);
  requestAnimationFrame(() => {
    document.getElementById("messagesEnd")?.scrollIntoView({ behavior: "smooth" });
  });
};

const showTyping = () => {
  typingIndicator.textContent = `${familierName} écrit...`;
};

const hideTyping = () => {
  typingIndicator.textContent = "";
};

// ============================================================
// LOGIQUE DE RÉPONSE
// ============================================================
const generateResponse = (userText) => {
  // Détection prioritaire des crises
  const crisisType = detectCrisis(userText);
  if (crisisType) {
    return { text: getCrisisResponse(crisisType, familierStyle), isCrisis: true };
  }

  const category = detectCategory(userText);
  const intensity = detectIntensity(userText);

  conversationContext.lastCategory = category;
  conversationContext.lastIntensity = intensity;
  conversationContext.messageCount++;

  let response = getResponse(familierStyle, category, intensity);

  if (shouldAskFollowUp() && !["bonjour","aurevoir","gratitude","remerciement"].includes(category)) {
    const followUp = getFollowUp(familierStyle);
    response = response + " " + followUp;
    conversationContext.askedQuestion = true;
  } else {
    conversationContext.askedQuestion = false;
  }

  return { text: response || getResponse(familierStyle, "incompris", "faible"), isCrisis: false };
};

const sendMessage = () => {
  const text = messageInput.value.trim();
  if (!text) return;

  appendMessage(text, true);
  messageInput.value = "";
  sendButton.disabled = true;

  const delay = 600 + Math.random() * 800;
  showTyping();

  setTimeout(() => {
    hideTyping();
    const { text: responseText, isCrisis } = generateResponse(text);
    appendMessage(responseText, false, isCrisis);
    sendButton.disabled = false;
    messageInput.focus();
  }, delay);
};

sendButton.addEventListener("click", sendMessage);
messageInput.addEventListener("keydown", (e) => {
  if (e.key === "Enter") {
    e.preventDefault();
    sendMessage();
  }
});

loadFamilier();
</script>