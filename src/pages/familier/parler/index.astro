          transition,
          validation,
          generic,
          style === "energique"
            ? "On ralentit un peu, juste un instant, d'accord ?"
            : style === "sage"
            ? "On peut revenir à quelque chose de concret, ici et maintenant."
            : "On va essayer de revenir doucement à maintenant."
        )
