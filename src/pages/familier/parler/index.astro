    "espoir",
  ];

  const getTransition = (style, trend, emotion, topic) => {
    if (NO_META_TRANSITIONS.includes(emotion)) return "";
    if (
      ![
        "stress",
        "tristesse",
        "anxiete",
        "fatigue",
        "solitude",
        "rupture",
        "famille",
        "amitie",
        "estime",
        "colere",
        "confusion",
        "frustration",
        "ennui",
        "peur",
      ].includes(emotion)
    ) {
      return "";
    }

    const packs = TRANSITIONS[style] || TRANSITIONS.doux;

    if (trend === "worsening") return pickRandom(packs.worsening);
    if (trend === "improving") return pickRandom(packs.improving);
    if (isSameThemeRepeating(emotion, topic)) return pickRandom(packs.repeating);

    return "";
  };

  // ============================================================
  // SÉLECTIONS
  // ============================================================
  const usedResponses = new Set();

  const uniquePick = (pool, keyPrefix = "generic") => {
    if (!pool || !pool.length) return "";

    const available = pool.filter(
      (_, index) => !usedResponses.has(`${keyPrefix}_${index}`)
    );

    if (!available.length) {
      [...usedResponses]
        .filter((key) => key.startsWith(`${keyPrefix}_`))
        .forEach((key) => usedResponses.delete(key));
      return uniquePick(pool, keyPrefix);
    }

    const choice = pickRandom(available);
    const index = pool.indexOf(choice);
    usedResponses.add(`${keyPrefix}_${index}`);
    return choice;
  };

  const getValidation = (style, intensity) => {
    const pack = STYLE_VOICE[style] || STYLE_VOICE.doux;
    return uniquePick(
      pack.validation[intensity] || pack.validation.faible,
      `${style}_validation_${intensity}`
    );
  };

