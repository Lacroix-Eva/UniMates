  const detectEventType = (text, emotion) => {
    const lower = normalizeText(text);

    if (SMALL_TALK_PATTERNS.some((p) => p.test(lower))) {
      if (["bonjour"].includes(emotion) || /^(salut|bonjour|coucou|hey|yo|cc)$/.test(lower)) {
        return "greeting";
      }
