    });

    if (conversationContext.history.length > 12) {
      conversationContext.history.shift();
    }
  };

  const getMoodTrend = () => {
    if (conversationContext.moodTrend.length < 2) return "stable";

    const recent = conversationContext.moodTrend.slice(-3);
    const values = recent.map((item) => intensityValue[item.intensity] || 1);

    if (values[values.length - 1] > values[0]) return "worsening";
    if (values[values.length - 1] < values[0]) return "improving";
    return "stable";
  };

  const isSameThemeRepeating = (emotion, topic) => {
    const lastUserMessages = conversationContext.history
      .filter((entry) => entry.role === "user")
      .slice(-4);

    if (lastUserMessages.length < 3) return false;

    const sameEmotionCount = lastUserMessages.filter(
      (entry) => entry.emotion === emotion
    ).length;

    const sameTopicCount =
      topic !== "general"
        ? lastUserMessages.filter((entry) => entry.topic === topic).length
        : 0;

    return sameEmotionCount >= 3 || sameTopicCount >= 3;
  };

  const getLastAssistantQuestion = () => {
    const lastAssistant = [...conversationContext.history]
      .reverse()
      .find((entry) => entry.role === "assistant");

    if (!lastAssistant?.text) return "";
    return lastAssistant.text;
  };

  const isLikelyAnswerToPrevious = (text) => {
    const lower = normalizeText(text);
    const previousQuestion = normalizeText(getLastAssistantQuestion());

    if (!previousQuestion || !previousQuestion.includes("?")) return false;

    if (lower.length <= 24) return true;

    const answerMarkers = [
      "oui",
      "non",
      "bah",
      "ben",
      "c'est",
      "cest",
      "parce que",
      "mon",
      "ma ",
      "j'ai",
      "j ai",
      "c'est que",
      "cest que",
    ];

    return answerMarkers.some((marker) => lower.startsWith(marker));
  };

  // ============================================================
  // STRATÉGIES
  // ============================================================
  const chooseResponseStrategy = ({
    emotion,
    valence,
    intensity,
    topic,
    eventType,
    intent,
    causeLevel,
    trend,
    isAnswerToPrevious,
  }) => {
    if (eventType === "greeting" || eventType === "small_talk" || eventType === "thanks") {
      return "social_reply";
    }

    if (
      ["annonce_positive", "cadeau_recu", "soutien_recu", "succes", "achat"].includes(
        eventType
      )
    ) {
      return "celebrate_with_context";
    }

    if (intent === "celebrate" && valence === "positive") {
      return "celebrate_with_context";
    }

    if (trend === "worsening" && intensity === "fort") {
      return "soothe";
    }

    if (
      ["stress", "anxiete"].includes(emotion) &&
      ["moyen", "fort"].includes(intensity)
    ) {
      return intent === "help" ? "soothe_then_problem_solve" : "soothe";
    }

    if (
      ["tristesse", "solitude", "rupture", "estime", "famille", "amitie", "culpabilite"].includes(
        emotion
      )
    ) {
      return causeLevel === "vague"
        ? "validate_and_clarify"
        : "validate_and_deepen";
    }

    if (emotion === "colere" || emotion === "jalousie") {
      return causeLevel === "vague"
        ? "validate_and_clarify"
        : "validate_and_deepen";
    }

    if (emotion === "fatigue") {
      return intent === "help"
        ? "support_then_action"
        : causeLevel === "vague"
        ? "validate_and_clarify"
        : "validate_and_deepen";
    }

    if (emotion === "joie") {
      return causeLevel === "vague"
        ? "celebrate_light"
        : "celebrate_with_context";
    }

    if (emotion === "espoir") {
      return causeLevel === "vague"
        ? "celebrate_light"
        : "celebrate_with_context";
    }

    if (["confusion", "peur"].includes(emotion)) {
      return causeLevel === "vague"
        ? "validate_and_clarify"
        : "validate_and_deepen";
    }

    if (emotion === "frustration") {
      return causeLevel === "vague"
        ? "validate_and_clarify"
        : "validate_and_deepen";
    }

    if (emotion === "ennui") {
      return intent === "help"
        ? "support_then_action"
        : causeLevel === "vague"
        ? "validate_and_clarify"
        : "validate_and_deepen";
    }

    if (intent === "help") return "problem_solve";
    if (intent === "question") return "clarify";
    if (isAnswerToPrevious && causeLevel !== "vague") return "contextual_follow_up";
    if (causeLevel !== "vague") return "validate_and_deepen";
    return "validate_and_clarify";
  };

