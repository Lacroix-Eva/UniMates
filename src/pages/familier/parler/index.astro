      actions.appendChild(callLink);
      actions.appendChild(emergencyNote);
      div.appendChild(actions);
    }

    messagesContainer.appendChild(div);

    requestAnimationFrame(() => {
      document
        .getElementById("messagesEnd")
        ?.scrollIntoView({ behavior: "smooth" });
    });
  };

  const showTyping = (inputText = "") => {
    const length = inputText.length;
    const mood =
      length < 25
        ? `${familierName} écrit...`
        : length < 90
        ? `${familierName} réfléchit un peu...`
        : `${familierName} prend le temps de te répondre...`;

    typingIndicator.textContent = mood;
  };

  const hideTyping = () => {
    typingIndicator.textContent = "";
  };

  // ============================================================
  // CHARGEMENT FAMILIER
  // ============================================================
  const loadFamilier = async () => {
    if (!pb.authStore.isValid || !pb.authStore.model) return;

    try {
      const user = await pb.collection("users").getOne(pb.authStore.model.id);
      const raw = (user.familier || "plume").toString().toLowerCase();
      familierKey = FAMILIERS_CONFIG[raw] ? raw : "plume";

      const config = FAMILIERS_CONFIG[familierKey];
      familierStyle = config.style;

      let customisation = user.customisation || {};
      if (typeof customisation === "string") {
        try {
          customisation = JSON.parse(customisation);
        } catch {
          customisation = {};
        }
      }

      familierImagePath = config.images[0];

      if (customisation?.variantId) {
        const match = customisation.variantId.match(/_(\d+)/);
        if (match) {
          const idx = parseInt(match[1], 10) - 1;
          familierImagePath = config.images[idx] || config.images[0];
        }
      }

      familierName = config.name;

      if (familierAvatarMsg) {
        familierAvatarMsg.src = familierImagePath;
        familierAvatarMsg.alt = familierName;
      }

      if (welcomeText) {
        const welcomes = {
          doux: `Coucou ! Je suis ${familierName} et je suis là pour toi. 🌟 Comment tu vas aujourd'hui ?`,
          sage: `Bonjour ! Je suis ${familierName}. Je suis là pour t'écouter. Comment vas-tu aujourd'hui ?`,
          energique: `HEYYY ! Je suis ${familierName} et je suis trop content·e que tu sois là !! Comment tu vas ?`,
        };
        welcomeText.textContent = welcomes[familierStyle] || welcomes.doux;
      }
    } catch (err) {
      console.error("Erreur chargement familier :", err);
    }
  };

  // ============================================================
  // GÉNÉRATION
  // ============================================================
  const generateResponse = (userText) => {
    const crisisType = detectCrisis(userText);

    if (crisisType === "crise" || crisisType === "automutilation") {
      const response = getCrisisResponse(crisisType, familierStyle);
      rememberAssistantMessage(response, {
        strategy: "urgence",
        emotion: crisisType,
        intensity: "fort",
      });
      return { text: response, isCrisis: true };
    }

    const { emotion, scores } = detectEmotion(
      userText,
      conversationContext.lastEmotion
    );

    const intensity = detectIntensity(userText, scores);
    const topic = detectTopic(userText);
    const eventType = detectEventType(userText, emotion);
    const valence = detectValence(emotion, userText, eventType);
    const intent = detectIntent(userText, emotion, eventType);
    const causeLevel = detectCauseLevel(userText);
    const trend = getMoodTrend();
    const isAnswerToPrevious = isLikelyAnswerToPrevious(userText);

    updateConversationMemory({
      text: userText,
      emotion,
      intensity,
      topic,
      eventType,
      valence,
      intent,
      causeLevel,
    });

    if (crisisType === "detresse") {
      const response = getCrisisResponse("detresse", familierStyle);
      rememberAssistantMessage(response, {
        strategy: "apaiser",
        emotion,
        intensity,
        topic,
      });
      return { text: response, isCrisis: false };
    }

    const strategy = chooseResponseStrategy({
      emotion,
      valence,
      intensity,
      topic,
      eventType,
      intent,
      causeLevel,
      trend,
      isAnswerToPrevious,
    });

    const response = buildResponse({
      style: familierStyle,
      emotion,
      topic,
      valence,
      intensity,
      eventType,
      strategy,
      trend,
    });

    const finalText = response || "Je veux bien comprendre. Tu peux me l'expliquer autrement ?";

    conversationContext.lastMode = strategy;

    rememberAssistantMessage(finalText, {
      strategy,
      emotion,
      intensity,
      topic,
      eventType,
      valence,
      intent,
    });

    return {
      text: finalText,
      isCrisis: false,
    };
  };

  // ============================================================
  // ENVOI
  // ============================================================
  const sendMessage = () => {
    const text = messageInput.value.trim();
    if (!text) return;

    appendMessage(text, true);
    applyCrisisVisualMode(false);

    messageInput.value = "";
    sendButton.disabled = true;
    messageInput.disabled = true;

    showTyping(text);

    const normalized = normalizeText(text);
    const baseDelay = 500;
    const variableDelay = clamp(normalized.length * 14, 150, 1400);
    const delay = baseDelay + variableDelay;

    setTimeout(() => {
      hideTyping();

      const { text: responseText, isCrisis } = generateResponse(text);

      if (isCrisis) {
        applyCrisisVisualMode(true);
      }

      appendMessage(responseText, false, isCrisis);

      sendButton.disabled = false;
      messageInput.disabled = false;
      messageInput.focus();
    }, delay);
  };

  sendButton.addEventListener("click", sendMessage);

  messageInput.addEventListener("keydown", (e) => {
    if (e.key === "Enter") {
      e.preventDefault();
      sendMessage();
    }
  });

  loadFamilier();
</script>