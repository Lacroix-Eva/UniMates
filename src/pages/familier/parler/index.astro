    }

    if (strategy === "soothe_then_problem_solve") {
      return sentenceCase(
        joinParts(
          transition,
          validation,
          generic,
          style === "energique"
            ? "On va éviter de tout porter d'un coup."
            : style === "sage"
            ? "Il n'y a pas besoin de tout résoudre d'un seul mouvement."
            : "Tu n'as pas besoin de tout porter en une seule fois.",
          action
        )
      );
    }

    return sentenceCase(
      joinParts(
        transition,
        validation,
        generic,
        clarifyFallbacks[emotion] || clarifyFallbacks.neutre
      )
    );
  };

