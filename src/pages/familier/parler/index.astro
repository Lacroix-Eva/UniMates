  const hasNegationBefore = (text, index) => {
    const windowStart = Math.max(0, index - 28);
    const chunk = text.slice(windowStart, index);
    return NEGATIONS.some((neg) =>
      new RegExp(`\\b${escapeRegExp(neg)}\\b`).test(chunk)
    );
  };

  const hasRecoveryHintNear = (text, index, length) => {
    const start = Math.max(0, index - 20);
    const end = Math.min(text.length, index + length + 20);
    const chunk = text.slice(start, end);
    return RECOVERY_WORDS.some((word) => chunk.includes(word));
  };

  const hasIntensifierNear = (text, index, length) => {
    const start = Math.max(0, index - 16);
    const end = Math.min(text.length, index + length + 16);
    const chunk = text.slice(start, end);
    return INTENSIFIERS.some((word) => chunk.includes(word));
  };

  const scoreKeywordGroup = (text, entries) => {
    let score = 0;

    for (const entry of entries) {
      const regex = new RegExp(`\\b${escapeRegExp(entry.term)}\\b`, "g");
      let match;

      while ((match = regex.exec(text)) !== null) {
        let weight = entry.weight;

        if (hasNegationBefore(text, match.index)) weight -= 3;
        if (hasRecoveryHintNear(text, match.index, entry.term.length)) weight -= 2;
        if (hasIntensifierNear(text, match.index, entry.term.length)) weight += 1;

        score += weight;
      }
    }

    return score;
  };

  const detectEmotion = (text, lastEmotion = null) => {
    const lower = normalizeText(text);
    const scores = {};

    for (const [emotion, entries] of Object.entries(EMOTION_KEYWORDS)) {
      scores[emotion] = scoreKeywordGroup(lower, entries);
      if (lastEmotion && emotion === lastEmotion) scores[emotion] += 0.35;
    }

    const positiveBoost = POSITIVE_HINTS.some((word) => lower.includes(word));
    if (positiveBoost) {
      scores.joie = (scores.joie || 0) + 1.25;
      scores.tristesse = (scores.tristesse || 0) - 0.5;
      scores.anxiete = (scores.anxiete || 0) - 0.5;
      scores.stress = (scores.stress || 0) - 0.5;
    }

    const sorted = Object.entries(scores).sort((a, b) => b[1] - a[1]);
    const best = sorted[0];

    if (!best || best[1] < 0) {
      return { emotion: "neutre", scores };
    }

    return { emotion: best[0], scores };
