    if (THANKS_PATTERNS.some((p) => p.test(lower))) return "thanks";
    if (POSITIVE_EVENT_PATTERNS.some((p) => p.test(lower))) {
      if (lower.includes("cadeau") || lower.includes("offert")) return "cadeau_recu";
      if (lower.includes("aide") || lower.includes("soutenu") || lower.includes("encourage")) return "soutien_recu";
      if (lower.includes("achete") || lower.includes("voiture") || lower.includes("achat")) return "achat";
