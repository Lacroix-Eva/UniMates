const INTENSITY_WORDS = {
  faible: ["un peu","légèrement","parfois","vaguement","quelque peu","de temps en temps"],
  moyen: ["assez","pas mal","vraiment","beaucoup","souvent","assez souvent","plutôt"],
  fort: ["vraiment trop","completement","totalement","à fond","tellement","plus","je craque","j'en peux plus","je n'en peux plus","je peux plus","au bout","épuisé","effondr","plus du tout","trop trop","insupportable","horrible","terrible"],
};

const detectCategory = (text) => {
  const lower = text.toLowerCase();
  let scores = {};
  for (const [cat, words] of Object.entries(KEYWORDS)) {
    scores[cat] = 0;
    for (const w of words) {
      if (lower.includes(w)) scores[cat]++;
    }
  }
  const sorted = Object.entries(scores).sort((a,b) => b[1]-a[1]);
  if (sorted[0][1] === 0) return "neutre";
  return sorted[0][0];
};

const detectIntensity = (text) => {
  const lower = text.toLowerCase();
  for (const w of INTENSITY_WORDS.fort) {
    if (lower.includes(w)) return "fort";
  }
  for (const w of INTENSITY_WORDS.moyen) {
    if (lower.includes(w)) return "moyen";
  }
  return "faible";
};

const usedResponses = {};

const getResponse = (style, category, intensity) => {
  const pool = RESPONSES[style];
  if (!pool) return null;

  let responses;

  if (["gratitude","remerciement","bonjour","aurevoir","incompris"].includes(category)) {
    responses = pool[category];
  } else {
    const cat = pool[category] || pool.neutre;
    responses = cat[intensity] || cat.moyen || cat.faible || Object.values(cat)[0];
  }

  if (!responses || responses.length === 0) {
    const neutre = pool.neutre || pool.incompris;
    responses = Array.isArray(neutre) ? neutre : neutre.faible || neutre.moyen;
  }

  const key = `${style}_${category}_${intensity}`;
  if (!usedResponses[key]) usedResponses[key] = [];

  let available = responses.filter((_, i) => !usedResponses[key].includes(i));
  if (available.length === 0) {
    usedResponses[key] = [];
    available = responses;
  }

  const idx = Math.floor(Math.random() * available.length);
  const actualIdx = responses.indexOf(available[idx]);
  usedResponses[key].push(actualIdx);

  return responses[actualIdx];
};

