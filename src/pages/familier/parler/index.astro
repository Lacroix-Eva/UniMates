      jalousie: "Qu'est-ce qui te rend aussi jaloux·se ?",
      neutre: "Tu veux m'en dire un peu plus ?",
    };

    if (strategy === "social_reply") {
      return sentenceCase(getSocialReply(style, eventType, valence));
    }

    if (strategy === "celebrate_light") {
      return sentenceCase(
        joinParts(
          cheer,
