    }

    if (eventType === "thanks") {
      return uniquePick(pack.thanks, `${style}_thanks`);
    }

    if (valence === "positive") {
      return uniquePick(pack.small_talk_positive, `${style}_small_positive`);
    }

    return uniquePick(pack.small_talk_neutral, `${style}_small_neutral`);
  };

