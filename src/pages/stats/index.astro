---
import LayoutProtege from "../../layouts/LayoutProtege.astro";
---

<LayoutProtege
    nomPage="Mes Stats"
    titre_page="Mes statistiques"
    intro_page="Suis ton évolution au quotidien"
>
    <div class="w-full max-w-sm mx-auto space-y-6">

        <!-- État vide -->
        <div id="emptyState" class="hidden space-y-4">
            <div class="bg-gradient-custom border-2 rounded-4xl shadow-md p-8 flex flex-col items-center gap-4">
                <div class="text-6xl">🌱</div>
                <div class="space-y-2 text-center">
                    <h3>Rien à voir pour l'instant !</h3>
                    <p class="opacity-70 text-sm">Enregistre ton premier mood pour voir tes statistiques apparaître ici.</p>
                </div>
                <a
                    href="/mood/enregistrer/index.html"
                    class="inline-flex items-center justify-center font-balsamiq-sans font-bold text-base py-3 px-8 border-2 rounded-4xl bg-secondary shadow-md transition-all active:bg-accent"
                >
                    Enregistrer mon mood 😊
                </a>
            </div>
        </div>

        <!-- Contenu stats -->
        <div id="statsContent" class="space-y-6">

            <!-- Streak -->
            <div class="bg-gradient-custom border-2 rounded-4xl shadow-md p-6 flex items-center gap-4">
                <div class="flex flex-col items-center justify-center bg-secondary border-2 rounded-3xl w-20 h-20 shrink-0 shadow-inner">
                    <span id="streakCount" class="font-balsamiq-sans font-bold text-3xl leading-none">0</span>
                    <span class="text-xs font-balsamiq-sans font-bold opacity-70">jours</span>
                </div>
                <div class="flex-1">
                    <h3 class="text-left">Streak actuel 🔥</h3>
                    <p id="streakMessage" class="text-left text-sm opacity-80">Chargement...</p>
                </div>
            </div>

            <!-- Résumé chiffres -->
            <div class="bg-gradient-custom border-2 rounded-4xl shadow-md p-6 grid grid-cols-3 gap-3 text-center">
                <div class="flex flex-col items-center gap-1">
                    <span id="totalMoods" class="font-balsamiq-sans font-bold text-2xl text-accent">0</span>
                    <span class="text-xs opacity-70">Total moods</span>
                </div>
                <div class="flex flex-col items-center gap-1">
                    <span id="bestMoodEmoji" class="text-2xl">—</span>
                    <span class="text-xs opacity-70">Humeur fréquente</span>
                </div>
                <div class="flex flex-col items-center gap-1">
                    <span id="moodThisWeek" class="font-balsamiq-sans font-bold text-2xl text-accent">0</span>
                    <span class="text-xs opacity-70">Cette semaine</span>
                </div>
            </div>

            <!-- Calendrier 30 jours -->
            <div class="bg-gradient-custom border-2 rounded-4xl shadow-md p-6 space-y-3">
                <h3 class="text-left">Calendrier du mois 📅</h3>
                <div style="display:grid;grid-template-columns:repeat(7,1fr);gap:4px;text-align:center;">
                    <div style="font-size:11px;font-weight:bold;opacity:0.5;font-family:'Balsamiq Sans',cursive;">L</div>
                    <div style="font-size:11px;font-weight:bold;opacity:0.5;font-family:'Balsamiq Sans',cursive;">M</div>
                    <div style="font-size:11px;font-weight:bold;opacity:0.5;font-family:'Balsamiq Sans',cursive;">M</div>
                    <div style="font-size:11px;font-weight:bold;opacity:0.5;font-family:'Balsamiq Sans',cursive;">J</div>
                    <div style="font-size:11px;font-weight:bold;opacity:0.5;font-family:'Balsamiq Sans',cursive;">V</div>
                    <div style="font-size:11px;font-weight:bold;opacity:0.5;font-family:'Balsamiq Sans',cursive;">S</div>
                    <div style="font-size:11px;font-weight:bold;opacity:0.5;font-family:'Balsamiq Sans',cursive;">D</div>
                </div>
                <div id="moodCalendar" style="display:grid;grid-template-columns:repeat(7,1fr);gap:4px;"></div>
                <div style="display:flex;flex-wrap:wrap;gap:8px 12px;margin-top:4px;">
                    <span style="display:flex;align-items:center;gap:4px;font-size:11px;"><span style="width:10px;height:10px;border-radius:50%;background:#4ade80;display:inline-block;flex-shrink:0;"></span>Excellent</span>
                    <span style="display:flex;align-items:center;gap:4px;font-size:11px;"><span style="width:10px;height:10px;border-radius:50%;background:#60a5fa;display:inline-block;flex-shrink:0;"></span>Bien</span>
                    <span style="display:flex;align-items:center;gap:4px;font-size:11px;"><span style="width:10px;height:10px;border-radius:50%;background:#fbbf24;display:inline-block;flex-shrink:0;"></span>Neutre</span>
                    <span style="display:flex;align-items:center;gap:4px;font-size:11px;"><span style="width:10px;height:10px;border-radius:50%;background:#fb923c;display:inline-block;flex-shrink:0;"></span>Moyen</span>
                    <span style="display:flex;align-items:center;gap:4px;font-size:11px;"><span style="width:10px;height:10px;border-radius:50%;background:#f87171;display:inline-block;flex-shrink:0;"></span>Difficile</span>
                </div>
            </div>

            <!-- Graphique semaine -->
            <div class="bg-gradient-custom border-2 rounded-4xl shadow-md p-6 space-y-3">
                <h3 class="text-left">Évolution cette semaine 📈</h3>
                <div id="chartWrap" style="width:100%;height:140px;position:relative;">
                    <canvas id="weekChart" style="position:absolute;top:0;left:0;width:100%;height:100%;"></canvas>
                </div>
            </div>

            <!-- Barres répartition -->
            <div class="bg-gradient-custom border-2 rounded-4xl shadow-md p-6 space-y-3">
                <div style="display:flex;justify-content:space-between;align-items:center;">
                    <h3 class="text-left">Répartition des moods</h3>
                    <div style="display:flex;gap:4px; margin-left:8px;">
                        <button id="btnMonth" style="font-size:11px;padding:3px 12px;border-radius:999px;border:2px solid black;font-family:'Balsamiq Sans',cursive;font-weight:bold;background:#FFE881;cursor:pointer;">Mois</button>
                        <button id="btnAll" style="font-size:11px;padding:3px 12px;border-radius:999px;border:2px solid rgba(0,0,0,0.25);font-family:'Balsamiq Sans',cursive;font-weight:bold;background:transparent;cursor:pointer;">Tout</button>
                    </div>
                </div>
                <div id="moodBars" class="space-y-3"></div>
            </div>

        </div>
    </div>
</LayoutProtege>

<script type="module" is:inline>
import pb from "/pocketbase/pb.js";

const MOOD_CONFIG = {
  excellent: { emoji: "😊", label: "Excellent", color: "#4ade80", score: 5 },
  bien:      { emoji: "🙂", label: "Bien",      color: "#60a5fa", score: 4 },
  neutre:    { emoji: "😐", label: "Neutre",    color: "#fbbf24", score: 3 },
  moyen:     { emoji: "😕", label: "Moyen",     color: "#fb923c", score: 2 },
  difficile: { emoji: "😢", label: "Difficile", color: "#f87171", score: 1 },
};

const toDateStr = (d) => {
  const y = d.getFullYear();
  const m = String(d.getMonth() + 1).padStart(2, "0");
  const day = String(d.getDate()).padStart(2, "0");
  return `${y}-${m}-${day}`;
};

const today = new Date();
today.setHours(0, 0, 0, 0);

// ── CALENDRIER ──────────────────────────────────────────────
const renderCalendar = (moodByDay) => {
  const cal = document.getElementById("moodCalendar");
  cal.innerHTML = "";

  const days = [];
  for (let i = 29; i >= 0; i--) {
    const d = new Date(today);
    d.setDate(d.getDate() - i);
    days.push(d);
  }

  const firstDow = days[0].getDay(); // dimanche=0
  for (let i = 0; i < firstDow; i++) {
    cal.appendChild(document.createElement("div"));
  }

  days.forEach(d => {
    const dayStr = toDateStr(d);
    const mood = moodByDay[dayStr];
    const isToday = dayStr === toDateStr(today);

    const el = document.createElement("div");
    el.style.cssText = [
      "aspect-ratio:1",
      "border-radius:8px",
      "display:flex",
      "align-items:center",
      "justify-content:center",
      "font-size:10px",
      "font-weight:bold",
      isToday ? "outline:2.5px solid #000;outline-offset:1px;" : "",
    ].join(";");

    if (mood) {
      const key = (mood.mood || "").toLowerCase();
      const cfg = MOOD_CONFIG[key];
      el.style.backgroundColor = cfg ? cfg.color : "#d1d5db";
      el.title = cfg ? `${dayStr} : ${cfg.label}` : dayStr;
    } else {
      el.style.backgroundColor = isToday ? "#fde68a" : "#e5e7eb";
      el.style.opacity = "0.4";
    }

    el.textContent = d.getDate();
    cal.appendChild(el);
  });
};

// ── GRAPHIQUE SEMAINE ────────────────────────────────────────
const renderWeekChart = (moodByDay) => {
  const canvas = document.getElementById("weekChart");
  const wrap = document.getElementById("chartWrap");
  if (!canvas || !wrap) return;

  const W = wrap.clientWidth || 280;
  const H = 140;
  const dpr = window.devicePixelRatio || 1;

  canvas.width = W * dpr;
  canvas.height = H * dpr;
  canvas.style.width = W + "px";
  canvas.style.height = H + "px";

  const ctx = canvas.getContext("2d");
  ctx.scale(dpr, dpr);
  ctx.clearRect(0, 0, W, H);

  const dayNames = ["Dim", "Lun", "Mar", "Mer", "Jeu", "Ven", "Sam"];
  const padL = 30, padR = 10, padT = 14, padB = 26;
  const cW = W - padL - padR;
  const cH = H - padT - padB;

  const labels = [], scores = [], colors = [];
  for (let i = 6; i >= 0; i--) {
    const d = new Date(today);
    d.setDate(d.getDate() - i);
    labels.push(dayNames[d.getDay()]);
    const mood = moodByDay[toDateStr(d)];
    if (mood) {
      const key = (mood.mood || "").toLowerCase();
      const cfg = MOOD_CONFIG[key];
      scores.push(cfg ? cfg.score : null);
      colors.push(cfg ? cfg.color : null);
    } else {
      scores.push(null);
      colors.push(null);
    }
  }

  // Grilles horizontales
  ctx.strokeStyle = "rgba(0,0,0,0.07)";
  ctx.lineWidth = 1;
  for (let i = 1; i <= 4; i++) {
    const y = padT + cH - (cH * i / 4);
    ctx.beginPath(); ctx.moveTo(padL, y); ctx.lineTo(padL + cW, y); ctx.stroke();
  }

  // Emojis axe Y
  const yEmojis = ["😢","😕","😐","🙂","😊"];
  ctx.font = "11px serif";
  ctx.textAlign = "center";
  yEmojis.forEach((e, i) => {
    const y = padT + cH - (cH * i / 4) + 4;
    ctx.fillText(e, padL - 12, y);
  });

  const xOf = (i) => padL + (cW / 6) * i;
  const yOf = (s) => padT + cH - ((s - 1) / 4) * cH;

  // Ligne pointillée
  ctx.strokeStyle = "rgba(0,0,0,0.18)";
  ctx.lineWidth = 2;
  ctx.lineJoin = "round";
  ctx.setLineDash([5, 4]);
  let started = false;
  scores.forEach((s, i) => {
    if (s === null) { started = false; return; }
    if (!started) { ctx.beginPath(); ctx.moveTo(xOf(i), yOf(s)); started = true; }
    else ctx.lineTo(xOf(i), yOf(s));
  });
  ctx.stroke();
  ctx.setLineDash([]);

  // Cercles
  scores.forEach((s, i) => {
    if (s === null) return;
    ctx.beginPath();
    ctx.arc(xOf(i), yOf(s), 7, 0, Math.PI * 2);
    ctx.fillStyle = colors[i];
    ctx.fill();
    ctx.strokeStyle = "rgba(0,0,0,0.12)";
    ctx.lineWidth = 1.5;
    ctx.stroke();
  });

  // Labels jours
  ctx.fillStyle = "rgba(0,0,0,0.5)";
  ctx.font = "bold 10px 'Balsamiq Sans', cursive";
  ctx.textAlign = "center";
  labels.forEach((label, i) => ctx.fillText(label, xOf(i), H - 5));
};

// ── BARRES ──────────────────────────────────────────────────
const renderBars = (moodByDay, daysBack) => {
  const cutoff = daysBack
    ? toDateStr(new Date(today.getTime() - daysBack * 86400000))
    : null;

  const counts = {};
  Object.keys(MOOD_CONFIG).forEach(k => counts[k] = 0);
  Object.entries(moodByDay).forEach(([day, m]) => {
    if (cutoff && day < cutoff) return;
    const key = (m.mood || "").toLowerCase();
    if (key in counts) counts[key]++;
  });

  const total = Object.values(counts).reduce((a, b) => a + b, 0);
  const container = document.getElementById("moodBars");
  container.innerHTML = "";

  if (total === 0) {
    container.innerHTML = '<p style="text-align:center;opacity:0.5;font-size:13px;padding:8px 0;">Aucune donnée sur cette période</p>';
    return;
  }

  Object.entries(MOOD_CONFIG).forEach(([key, cfg]) => {
    const count = counts[key];
    const pct = Math.round((count / total) * 100);
    const row = document.createElement("div");
    row.style.cssText = "display:flex;flex-direction:column;gap:4px;";
    row.innerHTML = `
      <div style="display:flex;justify-content:space-between;align-items:center;">
        <span style="font-family:'Balsamiq Sans',cursive;font-weight:bold;font-size:13px;">${cfg.emoji} ${cfg.label}</span>
        <span style="opacity:0.55;font-size:11px;">${count} jour${count > 1 ? "s" : ""} · ${pct}%</span>
      </div>
      <div style="height:12px;background:rgba(0,0,0,0.08);border-radius:999px;overflow:hidden;">
        <div style="height:100%;width:${pct}%;background:${cfg.color};border-radius:999px;opacity:0.88;"></div>
      </div>
    `;
    container.appendChild(row);
  });
};

// ── INIT ────────────────────────────────────────────────────
const loadStats = async () => {
  if (!pb.authStore.isValid) return;
  const userId = pb.authStore.model.id;

  let allMoods = [];
  try {
    allMoods = await pb.collection("moods").getFullList({
      filter: `user = "${userId}"`,
      sort: "-created",
    });
  } catch (err) {
    console.error("Erreur:", err);
  }

  if (allMoods.length === 0) {
    document.getElementById("emptyState").classList.remove("hidden");
    document.getElementById("statsContent").classList.add("hidden");
    return;
  }

  document.getElementById("emptyState").classList.add("hidden");
  document.getElementById("statsContent").classList.remove("hidden");

  const moodByDay = {};
  allMoods.forEach(m => {
    const day = m.created.slice(0, 10);
    if (!moodByDay[day]) moodByDay[day] = m;
  });

  // Streak
  let streak = 0;
  const cursor = new Date(today);
  while (moodByDay[toDateStr(cursor)]) {
    streak++;
    cursor.setDate(cursor.getDate() - 1);
  }
  document.getElementById("streakCount").textContent = streak;
  document.getElementById("streakMessage").textContent =
    streak === 0 ? "Enregistre ton mood du jour pour commencer !"
    : streak === 1 ? "Bien parti ! Continue demain 💪"
    : streak < 7 ? `${streak} jours de suite, continue ! 🌟`
    : `${streak} jours sans interruption, incroyable ! 🏆`;

  // Résumé
  document.getElementById("totalMoods").textContent = Object.keys(moodByDay).length;

  const moodCounts = {};
  Object.values(moodByDay).forEach(m => {
    const k = (m.mood || "").toLowerCase();
    moodCounts[k] = (moodCounts[k] || 0) + 1;
  });
  const topMood = Object.entries(moodCounts).sort((a, b) => b[1] - a[1])[0]?.[0];
  document.getElementById("bestMoodEmoji").textContent =
    topMood && MOOD_CONFIG[topMood] ? MOOD_CONFIG[topMood].emoji : "—";

  const weekStart = new Date(today);
  weekStart.setDate(today.getDate() - 6);
  document.getElementById("moodThisWeek").textContent =
    Object.keys(moodByDay).filter(d => d >= toDateStr(weekStart)).length;

  renderCalendar(moodByDay);
  renderBars(moodByDay, 30);

  // Canvas : attendre le layout
  setTimeout(() => renderWeekChart(moodByDay), 100);

  document.getElementById("btnMonth").addEventListener("click", () => {
    renderBars(moodByDay, 30);
    document.getElementById("btnMonth").style.background = "#FFE881";
    document.getElementById("btnMonth").style.borderColor = "black";
    document.getElementById("btnAll").style.background = "transparent";
    document.getElementById("btnAll").style.borderColor = "rgba(0,0,0,0.25)";
  });
  document.getElementById("btnAll").addEventListener("click", () => {
    renderBars(moodByDay, null);
    document.getElementById("btnAll").style.background = "#FFE881";
    document.getElementById("btnAll").style.borderColor = "black";
    document.getElementById("btnMonth").style.background = "transparent";
    document.getElementById("btnMonth").style.borderColor = "rgba(0,0,0,0.25)";
  });
};

loadStats();
</script>