---
import LayoutProtege from "../layouts/LayoutProtege.astro";
---

<LayoutProtege
  nomPage="Accueil"
  titre_page="Bonjour ... !"
  intro_page="(date_du_jour)"
>
  <!-- Section Personnalisation -->
  <div class="my-6 w-full max-w-sm mx-auto space-y-3">
    <div
      class="p-4 rounded-2xl shadow-lg bg-linear-to-b from-base-200 to-[#FFE6BB] border border-base-300/60"
    >
      <div class="flex items-center gap-4">
        <img
          id="cardFamilierImage"
          src="/familiers/plume.png"
          alt="Ton familier"
          class="w-12 h-12 object-contain"
        />

      
        <p class="text-left">
          <span id="cardFamilierName">Plume</span> • En croissance
        </p>
      </div>
      <div
      class="rounded-xl bg-base-100/45 border border-base-300/60 p-3 space-y-2"
    >
      <div class="flex justify-between items-center">
        <span id="moodRatio" class="text-xs font-bold">0/10</span>
      </div>
      <progress
        id="moodProgress"
        class="progress progress-primary w-full"
        value="0"
        max="10"></progress>

      <div class="flex items-center justify-between text-xs">
        <p class="text-xs text-left">
          Il reste <span id="moodNeeded" class="font-bold">10</span> moods
        </p>
        <span id="moodPercent" class="font-bold">0%</span>
      </div>
    </div>
        <p id="progressStatus" class="text-xs text-left opacity-80">
          Chaque mood que tu enregistres aide <span id="cardFamilierName">Plume</span> à grandir !
        </p>
      </div>
    </div>
  </div>

  <button
    id="logoutButton"
    class="inline-flex items-center justify-center text-base-content font-balsamiq-sans font-bold text-lg py-3 px-10 border-2 rounded-4xl shadow-md w-full max-w-xs transition-all duration-300 ease-in-out transform bg-base-300 active:bg-info cursor-pointer"
  >
    Se déconnecter
  </button>
</LayoutProtege>

<script type="module" is:inline>
  import pb from "/pocketbase/pb.js";

  const headerFamilierImage = document.getElementById("familierImage");
  const cardFamilierImage = document.getElementById("cardFamilierImage");
  const cardFamilierName = document.getElementById("cardFamilierName");
  const progressStatus = document.getElementById("progressStatus");
  const moodRatio = document.getElementById("moodRatio");
  const moodProgress = document.getElementById("moodProgress");
  const moodNeeded = document.getElementById("moodNeeded");
  const moodPercent = document.getElementById("moodPercent");

  const baseImages = {
    plume: "/familiers/plume.png",
    sunny: "/familiers/sunny.png",
    buzzy: "/familiers/buzzy.png",
  };

  const familierNames = {
    plume: "Plume",
    sunny: "Sunny",
    buzzy: "Buzzy",
  };

  const loadFamilier = async () => {
    if (!pb.authStore.isValid || !pb.authStore.model) {
      return;
    }

    // Récupérer les données à jour depuis PocketBase
    let user = pb.authStore.model;
    try {
      const userId = pb.authStore.model.id;
      user = await pb.collection("users").getOne(userId);
      console.log("User data:", user);
      console.log("Customisation:", user.customisation);
      console.log("Type customisation:", typeof user.customisation);
    } catch (err) {
      console.error("Erreur lors du chargement du profil:", err);
    }

    const rawFamilier = (user.familier || "Plume").toString().toLowerCase();
    const familierKey = baseImages[rawFamilier] ? rawFamilier : "plume";

    // Charger l'image personnalisée si disponible
    let imagePath = baseImages[familierKey];

    // Parser customisation si c'est une string JSON
    let customisation = user.customisation || {};
    if (typeof customisation === "string") {
      try {
        customisation = JSON.parse(customisation);
      } catch {
        customisation = {};
      }
    }

    console.log("Customisation après parsing:", customisation);
    console.log("variantId:", customisation.variantId);

    if (customisation && customisation.variantId) {
      const variantId = customisation.variantId;
      const variantIndex = parseInt(variantId.split("_")[1]) - 1;
      console.log("variantIndex calculé:", variantIndex);
      const variants = {
        plume: [
          "/familiers/plume.png",
          "/familiers/plume2.png",
          "/familiers/plume3.png",
          "/familiers/plume4.png",
          "/familiers/plume5.png",
          "/familiers/plume6.png",
          "/familiers/plume7.png",
        ],
        sunny: [
          "/familiers/sunny.png",
          "/familiers/sunny2.png",
          "/familiers/sunny3.png",
          "/familiers/sunny4.png",
          "/familiers/sunny5.png",
          "/familiers/sunny6.png",
          "/familiers/sunny7.png",
        ],
        buzzy: [
          "/familiers/buzzy.png",
          "/familiers/buzzy2.png",
          "/familiers/buzzy3.png",
          "/familiers/buzzy4.png",
          "/familiers/buzzy5.png",
          "/familiers/buzzy6.png",
          "/familiers/buzzy7.png",
        ],
      };

      const list = variants[familierKey] || variants.plume;
      imagePath = list[variantIndex] || list[0];
      console.log("Image path finale:", imagePath);
    }

    if (headerFamilierImage) {
      headerFamilierImage.src = imagePath;
    }

    if (cardFamilierImage) {
      cardFamilierImage.src = imagePath;
      cardFamilierImage.alt = familierNames[familierKey] || "Ton familier";
    }

    if (cardFamilierName) {
      cardFamilierName.textContent =
        familierNames[familierKey] || "Ton familier";
    }
  };

  const loadMoodProgress = async () => {
    if (!pb.authStore.isValid || !pb.authStore.model) {
      return;
    }

    try {
      const userId = pb.authStore.model.id;
      const moods = await pb.collection("moods").getFullList({
        filter: `user = "${userId}"`,
      });

      const count = moods.length;
      const maxMoods = 10;
      const progressValue = Math.min(count, maxMoods);
      const remaining = Math.max(0, maxMoods - count);
      const percent = Math.round((progressValue / maxMoods) * 100);

      if (moodRatio) moodRatio.textContent = `${progressValue}/${maxMoods}`;
      if (moodProgress) {
        moodProgress.value = progressValue;
        moodProgress.max = maxMoods;
      }
      if (moodNeeded) moodNeeded.textContent = remaining;
      if (moodPercent) moodPercent.textContent = `${percent}%`;

      if (progressStatus) {
        progressStatus.textContent =
          remaining === 0
            ? "Bravo, récompense débloquée 🎉"
            : `Encore ${remaining} mood${remaining > 1 ? "s" : ""} et c'est gagné ✨`;
      }

      console.log("Moods loaded:", count);
    } catch (err) {
      console.error("Erreur lors du chargement des moods:", err);
      // Si la collection n'existe pas encore, on initialise avec 0
      if (moodRatio) moodRatio.textContent = "0/10";
      if (moodProgress) {
        moodProgress.value = 0;
        moodProgress.max = 10;
      }
      if (moodNeeded) moodNeeded.textContent = "10";
      if (moodPercent) moodPercent.textContent = "0%";
    }
  };

  const logoutButton = document.getElementById("logoutButton");
  logoutButton.addEventListener("click", () => {
    pb.authStore.clear();
    window.location.href = "/";
  });

  loadFamilier();
  loadMoodProgress();
</script>
